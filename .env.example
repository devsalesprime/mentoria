# Prosperus Mentoria Platform — Environment Variables
# Copy this file to .env and fill in the values

# HubSpot CRM Integration
HUBSPOT_PRIVATE_TOKEN=your-hubspot-private-app-token
HUBSPOT_WIN_STAGE=closedwon

# Server
PORT=3005
NODE_ENV=development

# Authentication (REQUIRED — server will not start without JWT_SECRET)
# Generate JWT_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
# Generate hash: node -e "console.log(require('bcryptjs').hashSync('your-password', 12))"
ADMIN_PASSWORD_HASH=

# Google AI (Gemini)
GEMINI_APIKEY=your-gemini-api-key
